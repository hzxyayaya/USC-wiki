{
  "name": "usc-wiki",
  "type": "module",
  "version": "1.0.0",
  "description": "USC Wiki — Next.js + Fumadocs",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "sync:vault": "node scripts/sync-vault-assets.mjs",
    "sync:doc-meta": "node scripts/sync-doc-meta.mjs",
    "build:search": "tsx scripts/build-search-index.ts",
    "postinstall": "fumadocs-mdx",
    "predev": "pnpm run sync:vault && pnpm run build:search",
    "dev": "next dev --webpack",
    "start": "next start",
    "prebuild": "pnpm run sync:vault && pnpm run build:search",
    "build": "next build",
    "preview": "npx serve out"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@orama/tokenizers": "^3.1.18",
    "@types/mdx": "^2.0.14",
    "fumadocs-core": "^16.11.4",
    "fumadocs-mdx": "^15.1.1",
    "fumadocs-ui": "^16.11.4",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pagefind/default-ui": "^1.5.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}

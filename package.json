{
  "name": "usc-wiki",
  "type": "module",
  "version": "1.0.0",
  "description": "Astro Starlight campus wiki",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "sync:vault": "node scripts/sync-vault-assets.mjs",
    "sync:doc-meta": "node scripts/sync-doc-meta.mjs",
    "sync:pagefind": "node scripts/sync-pagefind.mjs",
    "search:build": "pnpm run build && pnpm run sync:pagefind",
    "ensure:search": "node scripts/ensure-search-index.mjs",
    "predev": "pnpm run sync:vault && pnpm run ensure:search",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "pnpm run sync:vault",
    "build": "astro build",
    "postbuild": "pnpm run sync:pagefind",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.3.1",
    "katex": "^0.17.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "starlight-theme-galaxy": "^0.8.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@pagefind/default-ui": "^1.5.2",
    "pagefind": "^1.5.2"
  }
}

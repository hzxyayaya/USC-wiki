---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const noteCount = docs.length;

const sections = [
	{
		title: '新生入门',
		description: '校园网、校历与入学须知。',
		href: '/新生入门/',
		accent: 'blue',
	},
	{
		title: '学习指南',
		description: '选课、GPA、课程攻略、资料与学院信息。',
		href: '/学习指南/',
		accent: 'cyan',
	},
	{
		title: '校园生活',
		description: '食堂快递、吃喝玩乐与常用软件。',
		href: '/校园生活/',
		accent: 'green',
	},
	{
		title: '事务办理',
		description: '报销、研学、驾照等办事流程。',
		href: '/事务办理/',
		accent: 'amber',
	},
	{
		title: '竞赛与资源',
		description: '竞赛、模板、教程与软件推荐。',
		href: '/竞赛与资源/',
		accent: 'orange',
	},
	{
		title: '在线工具',
		description: 'GPA 计算器、倒计时与 Markdown 编辑器。',
		href: '/在线工具/',
		accent: 'violet',
	},
];

const highlights = [
	{ title: '选课指南', href: '/学习指南/教务指南/选课指南/' },
	{ title: 'GPA', href: '/学习指南/教务指南/gpa/' },
	{ title: '校园生活指南', href: '/校园生活/生活指南/' },
	{ title: '软件推荐', href: '/竞赛与资源/软件与模板/software/' },
	{ title: '模板下载', href: '/竞赛与资源/软件与模板/templates/' },
	{ title: '在线工具', href: '/在线工具/' },
];
---

<StarlightPage
	frontmatter={{
		title: 'USC Wiki',
		description: '南华大学校园知识库',
		template: 'splash',
		editUrl: false,
	}}
>
	<section class="home-hero">
		<div class="hero-copy">
			<p class="eyebrow">USC Wiki</p>
			<h1>南华大学校园知识库</h1>
			<p class="lead">把课程攻略、校园生活、事务办理与实用资源整理成一个更易查找的入口。</p>
			<div class="hero-actions">
				<a class="primary-action" href="/新生入门/">新生入门</a>
				<a class="secondary-action" href="/学习指南/">学习指南</a>
			</div>
			<p class="disclaimer">本站内容由学生社区贡献，仅供参考，不代表南华大学官方立场。</p>
		</div>
		<div class="hero-panel" aria-label="站点概览">
			<span>当前收录</span>
			<strong>{noteCount}</strong>
			<span>篇笔记</span>
		</div>
	</section>

	<section class="section-grid" aria-label="分类入口">
		{sections.map((section) => (
			<a class={`section-card ${section.accent}`} href={section.href}>
				<h2>{section.title}</h2>
				<p>{section.description}</p>
			</a>
		))}
	</section>

	<section class="quick-links" aria-label="常用入口">
		<h2>常用入口</h2>
		<div>
			{highlights.map((item) => (
				<a href={item.href}>{item.title}</a>
			))}
		</div>
	</section>
</StarlightPage>

<style>
	:global(h1#_top) {
		display: none;
	}

	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 220px;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.75rem, 5vw, 4rem) 0 2.5rem;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--sl-color-accent-high);
		font-weight: 700;
	}

	.home-hero h1 {
		max-width: 760px;
		margin: 0;
		font-size: clamp(2.25rem, 5.2vw, 4.6rem);
		line-height: 1.05;
		text-wrap: balance;
	}

	.lead {
		max-width: 620px;
		margin: 1.25rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: 1.2rem;
		line-height: 1.7;
	}

	.disclaimer {
		max-width: 620px;
		margin: 1rem 0 0;
		color: var(--sl-color-gray-3);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.primary-action,
	.secondary-action,
	.quick-links a {
		border-radius: 8px;
		text-decoration: none;
	}

	.primary-action,
	.secondary-action {
		display: inline-flex;
		align-items: center;
		min-height: 2.75rem;
		padding: 0.65rem 1rem;
		font-weight: 700;
	}

	.primary-action {
		background: var(--sl-color-accent-high);
		color: var(--sl-color-black);
	}

	.secondary-action {
		border: 1px solid var(--sl-color-gray-5);
		color: var(--sl-color-white);
	}

	.hero-panel {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 8px;
		padding: 1.25rem;
		background: color-mix(in srgb, var(--sl-color-bg), var(--sl-color-accent-low) 10%);
	}

	.hero-panel span,
	.hero-panel strong {
		display: block;
	}

	.hero-panel span {
		color: var(--sl-color-gray-2);
	}

	.hero-panel strong {
		margin: 0.35rem 0;
		color: var(--sl-color-white);
		font-size: 3rem;
		line-height: 1;
	}

	.section-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.section-card {
		display: block;
		min-height: 140px;
		border: 1px solid var(--sl-color-gray-5);
		border-top: 4px solid var(--accent-line);
		border-radius: 8px;
		padding: 1.1rem;
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--accent-line), transparent 88%), transparent 55%),
			color-mix(in srgb, var(--sl-color-bg), var(--sl-color-gray-6) 42%);
		color: inherit;
		text-decoration: none;
		transition:
			border-color 160ms ease,
			transform 160ms ease,
			box-shadow 160ms ease;
	}

	.section-card:hover {
		border-color: var(--accent-line);
		box-shadow: 0 10px 30px color-mix(in srgb, var(--accent-line), transparent 84%);
		transform: translateY(-2px);
	}

	.section-card:focus-visible {
		outline: 2px solid var(--accent-line);
		outline-offset: 3px;
	}

	.section-card h2 {
		margin: 0;
		font-size: 1.15rem;
		text-decoration: none;
	}

	.section-card p {
		margin: 0.75rem 0 0;
		color: var(--sl-color-gray-2);
		line-height: 1.65;
		text-decoration: none;
	}

	.section-card.blue {
		--accent-line: #79a7ff;
	}

	.section-card.cyan {
		--accent-line: #5ec8d8;
	}

	.section-card.green {
		--accent-line: #7bd88f;
	}

	.section-card.amber {
		--accent-line: #f3be62;
	}

	.section-card.orange {
		--accent-line: #f0a060;
	}

	.section-card.violet {
		--accent-line: #b6a0ff;
	}

	.quick-links {
		margin-top: 2.5rem;
		padding-bottom: 3rem;
	}

	.quick-links h2 {
		margin: 0 0 1rem;
		font-size: 1.25rem;
	}

	.quick-links div {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.quick-links a {
		border: 1px solid var(--sl-color-gray-5);
		padding: 0.55rem 0.8rem;
		color: var(--sl-color-white);
		background: color-mix(in srgb, var(--sl-color-bg), var(--sl-color-gray-6) 45%);
		transition:
			border-color 160ms ease,
			background 160ms ease;
	}

	.quick-links a:hover {
		border-color: var(--sl-color-accent-high);
		background: color-mix(in srgb, var(--sl-color-bg), var(--sl-color-accent-low) 12%);
	}

	@media (max-width: 900px) {
		.home-hero,
		.section-grid {
			grid-template-columns: 1fr;
		}

		.hero-panel {
			max-width: 260px;
		}
	}
</style>

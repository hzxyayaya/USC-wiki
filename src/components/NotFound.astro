<div class="wiki-not-found">
	<p class="wiki-not-found-code" aria-hidden="true">404</p>
	<h1 id="_top" data-page-title class="wiki-not-found-title">页面未找到</h1>
	<p class="wiki-not-found-desc">抱歉，我们找不到您要访问的页面。</p>
	<button type="button" class="wiki-not-found-back" data-wiki-not-found-back>回退</button>
</div>

<script>
	for (const button of document.querySelectorAll('[data-wiki-not-found-back]')) {
		button.addEventListener('click', () => {
			if (window.history.length > 1) {
				window.history.back();
				return;
			}
			window.location.href = '/';
		});
	}
</script>

